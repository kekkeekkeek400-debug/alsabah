# ==========================================
# مفاتيح نظام الذكاء الاصطناعي المجانية (Zero-Cost Setup)
# ==========================================

# 1. مفتاح Groq ⚡ (أسرع وأذكى محرك مجاني)
# يستخدم لتشغيل العقل المدبر، والوكلاء، ومحرك التدقيق الذاتي.
# احصل عليه مجاناً من: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. مفتاح Gemini 👁️ (للاستخدام المحدود فقط)
# يستخدم حصرياً في محرك الرؤية (Vision Engine) لقراءة الصور المرسلة من العملاء.
# بما أننا نستخدمه للصور فقط، فلن تتجاوز الباقة المجانية أبداً.
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxx
